# ==================== BOT CONFIG ====================
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=HinataBot

# ==================== GROQ AI ====================
GROQ_API_KEY=gsk_your_groq_api_key_here

# ==================== MONGODB ====================
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/hinata-bot?retryWrites=true&w=majority

# ==================== LOGGING ====================
LOG_LEVEL=info

# ==================== ADMIN ====================
OWNER_ID=your_telegram_user_id
SUDO_USERS=your_id,another_id

# ==================== OPTIONAL ====================
REDIS_URL=redis://localhost:6379
PORT=3000
